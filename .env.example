# LinuxServer Chrome Environment Variables
# https://docs.linuxserver.io/images/docker-chrome/

# Timezone
TZ=Europe/Madrid

# Optional: Custom user and password for access
CUSTOM_USER=usuario
PASSWORD=contraseña_segura

# Language (Spanish Spain)
LC_ALL=es_ES.UTF-8

# Additional flags to pass to Chrome on launch
CHROME_CLI=https://www.google.es
